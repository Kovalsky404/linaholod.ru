# ──────────────────────────────────────────────────────────────
# Скопируйте этот файл в .env.local и заполните значения.
# .env* не коммитятся (см. .gitignore).
# ──────────────────────────────────────────────────────────────

# Публичный URL сайта — для metadataBase, OG, sitemap, robots, JSON-LD.
# В проде укажите реальный домен (https://...). Без слэша в конце.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Telegram — уведомления о заявках с формы записи.
# Токен бота: получить у @BotFather.
TELEGRAM_BOT_TOKEN=
# ID чата/канала, куда бот шлёт заявки (узнать через @userinfobot).
# Можно указать НЕСКОЛЬКО получателей через запятую: 111111111,222222222
# Каждый получатель должен сначала написать боту /start (или бот — в группе).
TELEGRAM_CHAT_ID=

# ──────────────────────────────────────────────────────────────
# Sanity (CMS)
# ──────────────────────────────────────────────────────────────
# Project ID из manage.sanity.io (проект клиента). Публичная переменная.
NEXT_PUBLIC_SANITY_PROJECT_ID=
# Датасет (обычно production). Публичная переменная.
NEXT_PUBLIC_SANITY_DATASET=production
# Версия API — дата в формате YYYY-MM-DD (фиксирует поведение API).
NEXT_PUBLIC_SANITY_API_VERSION=2026-06-01
# Токен чтения (Editor/Viewer) — ТОЛЬКО на сервере, без NEXT_PUBLIC.
# Создать: manage.sanity.io → API → Tokens.
SANITY_API_READ_TOKEN=
