# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (committing .env.example only)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# MCP config (contains Figma API token)
.mcp.json

# Figma asset downloads
figma-assets/

# Client materials (keep brief.md + references tracked, ignore heavy/private)
_client/assets/
_client/data/

# Playwright
/test-results/
/playwright-report/
/playwright/.cache/
